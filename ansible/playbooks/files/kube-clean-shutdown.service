[Unit]
Description=Graceful Kubernetes Shutdown Hook
DefaultDependencies=no
Conflicts=shutdown.target reboot.target halt.target poweroff.target
Before=shutdown.target reboot.target halt.target poweroff.target containerd.service kubelet.service

[Service]
Type=oneshot
ExecStart=/bin/true
ExecStop=/usr/local/bin/kube-clean-shutdown.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
